# ─── Aplicação ─────────────────────────────────────────────────────────────────────
APP_NAME="Remoto 24h"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seudominio.com
APP_TIMEZONE=Africa/Luanda
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Base de Dados (PostgreSQL) ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=remoto24h
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

# ─── Sessão ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# ─── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=database

# ─── Filas (Queue) ────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Email ─────────────────────────────────────────────────────────────────────
# Opções: smtp | mailgun | ses | postmark | log (só para dev)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── WebSockets (Pusher / Channels) ──────────────────────────────────────
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Variáveis expostas ao front-end (Vite) — devem coincidir com as acima
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

# ─── Sanctum (SPA / API auth) ────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=seudominio.com,localhost

# ─── Sistema de Ficheiros ────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# Para produção com S3-compatível (ex: Cloudflare R2, AWS S3):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Redis (opcional) ────────────────────────────────────────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=
# REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"

/* Currency converter defaults */
# How many Angolan Kz per 1 BRL (used as fallback when live fetch fails)
AOA_PER_BRL=41.5
# Time-to-live for cached AOA rate in seconds
AOA_RATE_TTL=3600
# Provider for live rate (exchangerate.host by default)
AOA_RATE_PROVIDER=exchangerate.host
